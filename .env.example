# Database
DefaultConnection=Server=YOUR_SERVER;Port=3306;Database=YOUR_DB;User=YOUR_USER;Password=YOUR_PASSWORD;

# JWT Settings
JwtSettings__SecretKey=REPLACE_WITH_YOUR_STRONG_SECRET_KEY
JwtSettings__Issuer=HotstarApi
JwtSettings__Audience=HotstarClients
JwtSettings__ExpiryDays=7

# Razorpay Settings
RazorpaySettings__KeyId=rzp_test_YOUR_KEY_ID
RazorpaySettings__KeySecret=YOUR_KEY_SECRET
